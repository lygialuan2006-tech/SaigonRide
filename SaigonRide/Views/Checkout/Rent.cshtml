@model SaigonRide.Models.entities.Vehicle
@{ ViewData["Title"] = "Lên lịch trình"; }

<!-- Load Leaflet.js -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .dash-line { position: absolute; left: 11px; top: 35px; height: 35px; border-left: 2px dashed #ccc; }
    .modern-input { background-color: #f8f9fa; border: 1px solid #e9ecef; border-radius: 12px; font-weight: bold; }
    .modern-input:focus { background-color: #fff; box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15); border-color: #198754; }
    #returnMap { height: 250px; border-radius: 12px; z-index: 1; border: 2px solid #e9ecef; }
</style>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <!-- NÚT BACK THẦN THÁNH ĐÂY RỒI -->
            <a href="javascript:history.back()" class="btn btn-light rounded-circle me-3 shadow-sm"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">Lên lịch trình</h4>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 shadow-sm">
                    <i class="bi bi-bicycle text-success fs-3"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0 text-dark">@Model.Category</h5>
                    <span class="badge bg-success mt-1">@Model.PricePerMinute.ToString("N0")đ / phút</span>
                </div>
            </div>

            <form asp-controller="Checkout" asp-action="Receipt" method="post" id="rentForm">
                <input type="hidden" name="vehicleId" value="@Model.Id" />
                <input type="hidden" name="returnStationId" id="selectedReturnStationId" required />

                <div class="position-relative mb-4">
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-circle-fill text-primary mt-2 me-3" style="font-size: 0.7rem; z-index: 2;"></i>
                        <div class="flex-grow-1">
                            <label class="text-muted small fw-bold mb-1">Điểm lấy xe</label>
                            <input type="text" class="form-control modern-input text-muted" value="@Model.Station.LocationName" readonly />
                        </div>
                    </div>
                    
                    <div class="dash-line"></div>

                    <div class="d-flex align-items-start">
                        <i class="bi bi-geo-alt-fill text-danger mt-2 me-3" style="font-size: 1.1rem; margin-left: -3px; z-index: 2;"></i>
                        <div class="flex-grow-1">
                            <label class="text-muted small fw-bold mb-1">Trả xe ở đâu? (Chọn trên bản đồ)</label>
                            <!-- Input giả để hiện tên trạm, input thật bị ẩn ở trên -->
                            <input type="text" id="displayReturnStation" class="form-control modern-input bg-white text-danger" placeholder="Vui lòng click vào trạm trên bản đồ..." readonly required />
                        </div>
                    </div>
                </div>

                <!-- BẢN ĐỒ MINI CHỌN TRẠM TRẢ XE -->
                <div class="mb-4">
                    <div id="returnMap"></div>
                    <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle"></i> Trạm màu xám là đã hết chỗ đỗ xe. Trạm màu vàng là đang có khuyến mãi.</small>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <i class="bi bi-clock-fill text-warning mt-2 me-3" style="font-size: 1rem;"></i>
                    <div class="flex-grow-1">
                        <label class="text-muted small fw-bold mb-1">Thời gian dự kiến (phút)</label>
                        <input type="number" name="duration" class="form-control modern-input" placeholder="Ví dụ: 30" min="1" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 rounded-pill py-3 fw-bold fs-5 shadow">Tiếp tục thanh toán</button>
            </form>
        </div>
    </div>
</div>

<script>
    var map = L.map('returnMap').setView([10.785, 106.705], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

    var stations = @Html.Raw(ViewBag.StationsJson);
    var bounds = [];

    stations.forEach(function (st) {
        var finalLat = st.lat !== 0 ? st.lat : (st.id === 1 ? 10.776889 : 10.801534);
        var finalLng = st.lng !== 0 ? st.lng : (st.id === 1 ? 106.700806 : 106.711075);
        bounds.push([finalLat, finalLng]);

        var availableSlots = st.capacity - st.inventory;
        var isFull = availableSlots <= 0;
        
        // Logic đổi màu Marker: Hết chỗ = Đen/Xám, Khuyến mãi (Ví dụ id = 3 là Bình Thạnh) = Vàng, Bình thường = Xanh lá
        var markerColor = isFull ? 'filter: grayscale(100%);' : (st.id === 3 ? 'filter: hue-rotate(40deg);' : 'filter: hue-rotate(120deg);');
        
        var customIcon = L.divIcon({
            className: 'custom-div-icon',
            html: `<div style="text-align:center; ${markerColor}">
                       <i class="bi bi-geo-alt-fill fs-2 ${isFull ? 'text-secondary' : (st.id === 3 ? 'text-warning' : 'text-success')}"></i>
                   </div>`,
            iconSize: [30, 42],
            iconAnchor: [15, 42]
        });

        var marker = L.marker([finalLat, finalLng], { icon: customIcon }).addTo(map);
        
        var tooltipText = `<b>${st.name}</b><br>Chỗ trống: ${availableSlots}`;
        if(st.id === 3) tooltipText += `<br><span class="badge bg-warning text-dark mt-1">Giảm 15%</span>`;
        if(isFull) tooltipText += `<br><span class="badge bg-danger mt-1">Đã đầy</span>`;
        
        marker.bindTooltip(tooltipText, { permanent: false, direction: 'top' });

        marker.on('click', function () {
            if (isFull) {
                alert("Trạm này đã hết chỗ đỗ xe. Vui lòng chọn trạm khác!");
                return;
            }
            // Điền dữ liệu vào form
            document.getElementById('selectedReturnStationId').value = st.id;
            document.getElementById('displayReturnStation').value = st.name + " (Còn " + availableSlots + " chỗ)";
            document.getElementById('displayReturnStation').classList.remove('text-danger');
            document.getElementById('displayReturnStation').classList.add('text-success');
        });
    });

    if(bounds.length > 0) map.fitBounds(bounds, { padding: [20, 20] });
</script>