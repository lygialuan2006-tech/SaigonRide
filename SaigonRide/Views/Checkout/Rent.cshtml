@model SaigonRide.Models.entities.Vehicle
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{ ViewData["Title"] = Localizer["PageTitle"].Value; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .modern-input { background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; font-weight: bold; color: var(--text-color) !important; }
    .modern-input:focus { background-color: var(--card-bg); box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15); border-color: #198754; }
    .modern-input[readonly] { background-color: var(--bg-color); opacity: 0.8; }
    #returnMap { height: 550px; border-radius: 1rem; z-index: 1; border: 1px solid var(--border-color); }
</style>

<div class="container-fluid px-0">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="javascript:history.back()" class="btn btn-white bg-white shadow-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-arrow-left text-dark"></i></a>
        <div>
            <h3 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h3>
            <p class="text-muted mb-0">@Localizer["PageSubtitle"]</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Cột Trái: Bản đồ To đùng -->
        <div class="col-lg-7 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 p-2 bg-white h-100">
                <div id="returnMap"></div>
                <div class="d-flex justify-content-center gap-4 mt-3 pb-2">
                    <small class="text-muted"><i class="bi bi-circle-fill text-secondary me-1"></i>@Localizer["StationFull"]</small>
                    <small class="text-muted"><i class="bi bi-circle-fill text-success me-1"></i>@Localizer["StationAvailable"]</small>
                    <small class="text-muted"><i class="bi bi-circle-fill text-warning me-1"></i>@Localizer["StationPromo"]</small>
                </div>
            </div>
        </div>

        <!-- Cột Phải: Form Xác nhận -->
        <div class="col-lg-5 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 shadow-sm text-success">
                        <i class="bi @(Model.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") fs-2"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-0 text-dark">@Model.Category</h5>
                        <span class="badge bg-dark mt-1">@Model.PricePerMinute.ToString("N0")đ / min</span>
                    </div>
                </div>

                <form asp-controller="Checkout" asp-action="StartTimer" method="post" id="rentForm" class="d-flex flex-column h-100">
                    <input type="hidden" name="vehicleId" value="@Model.Id" />
                    <input type="hidden" name="returnStationId" id="selectedReturnStationId" required />

                    <div class="mb-4">
                        <label class="text-muted small fw-bold mb-2"><i class="bi bi-geo-alt text-primary me-1"></i> @Localizer["PickupPoint"]</label>
                        <input type="text" class="form-control modern-input shadow-none mb-3" value="@Model.Station.LocationName" readonly />

                        <label class="text-muted small fw-bold mb-2"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @Localizer["DropoffPoint"]</label>
                        <input type="text" id="displayReturnStation" class="form-control modern-input text-danger shadow-none" placeholder="@Localizer["SelectOnMap"]" readonly required style="cursor: pointer;" />
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5 shadow mt-auto rounded-pill">
                        @Localizer["StartRental"] <i class="bi bi-play-circle ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var map = L.map('returnMap').setView([10.785, 106.705], 13);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

    var stations = @Html.Raw(ViewBag.StationsJson);
    var bounds = [];

    stations.forEach(function (st) {
        var finalLat = st.lat !== 0 ? st.lat : (st.id === 1 ? 10.776889 : 10.801534);
        var finalLng = st.lng !== 0 ? st.lng : (st.id === 1 ? 106.700806 : 106.711075);
        bounds.push([finalLat, finalLng]);

        var availableSlots = st.capacity - st.inventory;
        var isFull = availableSlots <= 0;
        var markerColor = isFull ? 'filter: grayscale(100%); opacity: 0.7;' : (st.id === 3 ? 'filter: hue-rotate(40deg);' : 'filter: hue-rotate(120deg);');
        
        var customIcon = L.divIcon({
            className: 'custom-div-icon',
            html: `<div style="text-align:center; ${markerColor}"><i class="bi bi-geo-alt-fill fs-1 ${isFull ? 'text-secondary' : (st.id === 3 ? 'text-warning' : 'text-success')}" style="text-shadow: 0 2px 4px rgba(0,0,0,0.3);"></i></div>`,
            iconSize: [40, 50],
            iconAnchor: [20, 50]
        });

        var marker = L.marker([finalLat, finalLng], { icon: customIcon }).addTo(map);
        marker.bindTooltip(`<b>${st.name}</b><br>Slots: ${availableSlots}`, { direction: 'top', offset: [0, -35] });

        marker.on('click', function () {
            if (isFull) { alert("Station is full!"); return; }
            document.getElementById('selectedReturnStationId').value = st.id;
            document.getElementById('displayReturnStation').value = st.name + " (" + availableSlots + " slots left)";
            document.getElementById('displayReturnStation').classList.replace('text-danger', 'text-success');
        });
    });
    if(bounds.length > 0) map.fitBounds(bounds, { padding: [30, 30] });
</script>