@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["ActiveRental"];
    Layout = "~/Views/Shared/_Layout.cshtml"; // Giữ layout chuẩn, không phá nền
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Khung rộng rãi cho màn hình PC -->
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                
                <!-- HEADER CHUYẾN ĐI -->
                <div class="card-header bg-success text-white p-4 text-center border-0">
                    <span class="badge bg-white text-success rounded-pill mb-3 px-3 py-2 shadow-sm">
                        <i class="bi bi-circle-fill text-success border border-2 border-white rounded-circle me-2" style="font-size: 0.6rem; vertical-align: middle;"></i>
                        @Localizer["ActiveRental"]
                    </span>
                    <h3 class="mb-0 fw-bold">@ViewBag.VehicleCategory</h3>
                    <p class="mb-0 mt-2 text-white-50"><i class="bi bi-geo-alt-fill me-1"></i>Trạm đích: @ViewBag.StationName</p>
                </div>
                
                <div class="card-body p-5">
                    <div class="row align-items-center g-5">
                        
                        <!-- CỘT TRÁI: ĐỒNG HỒ ĐẾM THỜI GIAN -->
                        <div class="col-md-6 text-center border-end pe-md-4">
                            <p class="text-muted text-uppercase fw-bold mb-2">@Localizer["ElapsedTime"]</p>
                            
                            <!-- Font monospace hiển thị số to, không bị nhảy giật -->
                            <div class="display-2 fw-bold text-success mb-4" id="timerDisplay" style="font-family: 'Courier New', monospace; letter-spacing: 2px;">
                                00:00:00
                            </div>
                            
                            <!-- Nút cộng giờ -->
                            <div class="d-flex justify-content-center gap-2 mb-4 mb-md-0">
                                <form method="post" asp-action="AddMinutes" class="d-inline">
                                    <input type="hidden" name="vehicleId" value="@ViewBag.VehicleId" />
                                    <input type="hidden" name="minutes" value="30" />
                                    <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
                                        +30 min
                                    </button>
                                </form>
                                <form method="post" asp-action="AddMinutes" class="d-inline">
                                    <input type="hidden" name="vehicleId" value="@ViewBag.VehicleId" />
                                    <input type="hidden" name="minutes" value="60" />
                                    <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
                                        +60 min
                                    </button>
                                </form>
                            </div>
                        </div>
                        
                        <!-- CỘT PHẢI: CHI PHÍ TẠM TÍNH -->
                        <div class="col-md-6 ps-md-4">
                            <div class="bg-light p-4 rounded-4 shadow-sm border border-light">
                                <h5 class="fw-bold mb-4 text-dark border-bottom pb-3">Chi tiết chi phí</h5>
                                
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted fw-bold">@Localizer["Rate"]</span>
                                    <span class="fw-bold text-dark fs-5">@ViewBag.PricePerMinute.ToString("N0") ₫/min</span>
                                </div>
                                
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted fw-bold">@Localizer["CurrentCost"]</span>
                                    <span class="fw-bold text-dark fs-5" id="currentCost">0 ₫</span>
                                </div>
                                
                                <div class="d-flex justify-content-between mt-4 pt-3 border-top border-2 border-white">
                                    <span class="text-muted fw-bold text-uppercase mt-1">@Localizer["EstimatedTotal"]</span>
                                    <span class="fs-3 fw-bold text-danger" id="estimatedTotal">0 ₫</span>
                                </div>
                            </div>
                            
                            <!-- NÚT KẾT THÚC CHUYẾN ĐI -->
                            <div class="mt-4">
                                <form method="post" asp-action="EndRental">
                                    <input type="hidden" name="vehicleId" value="@ViewBag.VehicleId" />
                                    <button type="submit" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold py-3 shadow" onclick="return confirm('@Localizer["ConfirmEnd"]');">
                                        <i class="bi bi-stop-circle-fill me-2 fs-5"></i>@Localizer["EndRental"]
                                    </button>
                                </form>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // JS nhận thẳng số Unix Miliseconds từ C#, miễn nhiễm hoàn toàn với lỗi NaN
    let startTime = @(ViewBag.StartTimeUnix ?? "Date.now()");
    let additionalMinutes = @(ViewBag.AdditionalMinutes ?? 0);
    let pricePerMinute = @(ViewBag.PricePerMinute ?? 0);

    function formatTime(ms) {
        let totalSeconds = Math.floor(ms / 1000) + (additionalMinutes * 60);
        if (totalSeconds < 0) totalSeconds = 0;
        let hours = Math.floor(totalSeconds / 3600);
        let minutes = Math.floor((totalSeconds % 3600) / 60);
        let seconds = totalSeconds % 60;
        return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
    }

    function updateTimer() {
        let elapsed = Date.now() - startTime;
        document.getElementById('timerDisplay').textContent = formatTime(elapsed);

        let totalSeconds = Math.floor(elapsed / 1000) + (additionalMinutes * 60);
        let minutes = Math.ceil(totalSeconds / 60);
        if (minutes < 0) minutes = 0;
        
        let cost = minutes * pricePerMinute;
        let formattedCost = cost.toLocaleString('vi-VN') + ' ₫';
        
        document.getElementById('currentCost').textContent = formattedCost;
        document.getElementById('estimatedTotal').textContent = formattedCost;
    }

    // Chạy ngay 1 lần lúc load trang, rồi set interval mỗi 1 giây
    updateTimer();
    setInterval(updateTimer, 1000);
</script>