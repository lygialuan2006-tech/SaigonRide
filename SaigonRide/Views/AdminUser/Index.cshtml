@model IEnumerable<SaigonRide.Models.entities.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-people-fill text-primary me-2"></i>Danh sách Khách hàng</h5>
</div>

<!-- THANH TÌM KIẾM USER -->
<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white">
                <span class="input-group-text bg-white border-0 text-muted ps-4"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none px-2" placeholder="Tìm theo Tên, Email hoặc SĐT...">
                <button class="btn btn-primary fw-bold px-4" type="submit">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
                {
                    <a href="/AdminUser/Index" class="btn btn-light border-start px-3" title="Xóa tìm kiếm"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="border-bottom: 2px solid #dee2e6;">
                <tr>
                    <th class="ps-4">Hồ sơ</th>
                    <th>Liên hệ</th>
                    <th class="text-center">Vai trò</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@(user.AvatarUrl ?? "/images/avatars/default.png")"
                                         class="rounded-circle shadow-sm me-3" width="40" height="40" style="object-fit:cover;"
                                         onerror="this.src='https://ui-avatars.com/api/?name=@user.FullName&background=random'" />
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="text-muted small">ID: #@user.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div><i class="bi bi-envelope text-muted me-1"></i> @user.Email</div>
                                <div class="small"><i class="bi bi-telephone text-muted me-1"></i> @(user.Phone ?? "Chưa cập nhật")</div>
                            </td>
                            <td class="text-center">
                                @if (user.UserType == "Admin")
                                {
                                    <span class="badge bg-danger rounded-pill"><i class="bi bi-shield-lock-fill"></i> Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary rounded-pill">Khách hàng</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (user.IsBanned)
                                {
                                    <span class="badge bg-dark text-white rounded-pill">Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill">Đang hoạt động</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="/AdminUser/Edit/@user.Id" class="btn btn-sm btn-light text-primary me-1" title="Chỉnh sửa hồ sơ">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                @if (user.Email != "admin@saigonride.com")
                                {
                                    <form asp-action="ToggleBan" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @if (user.IsBanned)
                                        {
                                            <button type="submit" class="btn btn-sm btn-success fw-bold" title="Mở khóa tài khoản này">
                                                <i class="bi bi-unlock-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold" title="Khóa tài khoản này" onsubmit="return confirm('Bạn muốn khóa tài khoản này?');">
                                                <i class="bi bi-lock-fill"></i>
                                            </button>
                                        }
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">Không tìm thấy người dùng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>