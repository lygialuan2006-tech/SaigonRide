@{
    Layout = null; // Trang này không dùng chung Navbar để tạo hiệu ứng tràn màn hình
}
<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                background: radial-gradient(circle at center, #0a2e1f 0%, #000000 100%);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                overflow: hidden;
                font-family: 'Segoe UI', sans-serif;
            }

            .galaxy-overlay {
                position: absolute;
                width: 100%;
                height: 100%;
                background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
                opacity: 0.3;
            }

            .hero-content {
                z-index: 10;
                text-align: center;
            }

            .btn-get-started {
                background: #28a745;
                color: white;
                padding: 15px 40px;
                border-radius: 50px;
                text-decoration: none;
                font-weight: bold;
                box-shadow: 0 0 20px rgba(40, 167, 69, 0.5);
                transition: 0.3s;
            }

                .btn-get-started:hover {
                    transform: scale(1.1);
                    box-shadow: 0 0 40px rgba(40, 167, 69, 0.8);
                    color: white;
                }
    </style>
</head>
<body>
    <div class="galaxy-overlay"></div>
    <div class="hero-content">
        <h1 class="display-1 fw-bold mb-3" style="color: #4ade80;">SaigonRide</h1>
        <p class="fs-4 mb-5 text-secondary">Hệ thống thuê xe thông minh cho thành phố hiện đại</p>
        <a href="/Account/Login" class="btn-get-started">GET STARTED</a>
    </div>
</body>
</html>