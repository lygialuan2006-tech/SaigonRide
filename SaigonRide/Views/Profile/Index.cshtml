@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<style>
    /* CSS cực kỳ đơn giản để fix lỗi highlight tab xanh */
    .card-header .nav-tabs .nav-link { 
        color: var(--text-muted); 
        border: none; 
        background: transparent; 
        position: relative; 
        padding-bottom: 12px;
    }
    .card-header .nav-tabs .nav-link.active { 
        color: var(--accent-green) !important; 
        font-weight: bold; 
    }
    .card-header .nav-tabs .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 3px;
        background-color: var(--accent-green);
        border-radius: 3px 3px 0 0;
    }

    /* CSS cho PFP upload */
    .pfp-container:hover .pfp-edit-icon { opacity: 1; }
    .pfp-edit-icon { opacity: 0; transition: opacity 0.2s; }
</style>

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4 px-2">
            <a href="javascript:history.back()" class="btn btn-light rounded-circle me-3 shadow-sm text-dark"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h4>
        </div>

        <!-- HIỂN THỊ THÔNG BÁO TỪ CONTROLLER (ĐÃ ĐƯỢC DỊCH) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
            <div class="card-header bg-transparent border-bottom pt-4 pb-0 px-4">
                <ul class="nav nav-tabs border-0" id="settingsTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <!-- Mặc định mở Tab Tài khoản -->
                        <button class="nav-link active fw-bold py-3" id="account-tab" data-bs-toggle="tab" data-bs-target="#account" type="button" role="tab">@Localizer["TabAccount"]</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold py-3" id="pref-tab" data-bs-toggle="tab" data-bs-target="#pref" type="button" role="tab">@Localizer["TabPreferences"]</button>
                    </li>
                </ul>
            </div>
            
            <div class="card-body p-4">
                <div class="tab-content" id="settingsTabContent">
                    
                    <!-- TAB ACCOUNT -->
                    <div class="tab-pane fade show active" id="account" role="tabpanel">
                        <div class="text-center mb-4">
                            <!-- Khu vực PFP và Upload FORM ẩn -->
                            <div class="position-relative d-inline-block pfp-container">
                                <img id="avatarImage" src="@ViewBag.AvatarPath" class="rounded-circle d-block mx-auto mb-3 shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='https://ui-avatars.com/api/?name=@User.Identity.Name&background=0a3b22&color=fff&size=128'">
                                
                                <form id="avatarUploadForm" asp-controller="Profile" asp-action="UploadAvatar" method="post" enctype="multipart/form-data" class="position-absolute top-0 start-0 w-100 h-100 m-0 p-0" style="cursor: pointer;">
                                    <input type="file" name="avatarFile" id="avatarInput" accept="image/*" class="w-100 h-100 opacity-0" style="cursor: pointer;" onchange="this.form.submit()">
                                </form>
                                <div class="position-absolute bottom-0 end-0 bg-white rounded-circle d-flex justify-content-center align-items-center shadow-sm pfp-edit-icon" style="width: 25px; height: 25px; cursor: pointer;">
                                    <i class="bi bi-pencil-fill text-muted" style="font-size: 0.8rem;"></i>
                                </div>
                            </div>
                            <span class="badge bg-light text-muted border mt-1 px-3 py-2 rounded-pill">@(User.FindFirst("UserType")?.Value == "Tourist" ? Localizer["UserType_Tourist"] : Localizer["UserType_Local"])</span>
                        </div>
                        
                        <!-- FORM CẬP NHẬT THÔNG TIN TỪ claims/viewbag -->
                        <form asp-controller="Profile" asp-action="UpdateProfile" method="post" class="mt-4">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">@Localizer["LabelName"]</label>
                                <input type="text" name="fullName" class="form-control border-light shadow-none bg-light fw-bold" value="@ViewBag.CurrentName" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">@Localizer["LabelEmail"]</label>
                                <input type="email" name="email" class="form-control border-light shadow-none bg-light fw-bold" value="@ViewBag.CurrentEmail" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">@Localizer["LabelPhone"]</label>
                                <input type="tel" name="phone" class="form-control border-light shadow-none bg-light fw-bold" value="@ViewBag.CurrentPhone" required>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success rounded-pill py-3 fw-bold shadow-sm">@Localizer["BtnSave"] <i class="bi bi-save ms-1"></i></button>
                            </div>
                        </form>

                        <div class="mt-4 pt-4 border-top text-center">
                            <a href="javascript:void(0);" onclick="localStorage.removeItem('theme'); document.body.classList.remove('dark-mode'); window.location.href='/Account/Logout';" class="btn btn-outline-danger rounded-pill px-4 fw-bold">@Localizer["BtnLogout"]</a>
                        </div>
                    </div>

                    <!-- TAB TÙY CHỌN -->
                    <div class="tab-pane fade" id="pref" role="tabpanel">
                        <div class="list-group list-group-flush rounded-3 border">
                            <!-- Dark Mode Toggle -->
                            <div class="list-group-item d-flex justify-content-between align-items-center p-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-dark text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="bi bi-moon-stars-fill"></i></div>
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0">@Localizer["PrefDarkMode"]</h6>
                                        <small class="text-muted">@Localizer["PrefDarkModeDesc"]</small>
                                    </div>
                                </div>
                                <div class="form-check form-switch fs-4 mb-0">
                                    <input class="form-check-input" type="checkbox" id="darkModeSwitch">
                                </div>
                            </div>

                            <!-- Language Select -->
                            <div class="list-group-item d-flex justify-content-between align-items-center p-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="bi bi-translate"></i></div>
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0">@Localizer["PrefLanguage"]</h6>
                                        <small class="text-muted">@Localizer["PrefLanguageDesc"]</small>
                                    </div>
                                </div>
                                <div>
                                    <button class="btn btn-sm btn-light border rounded-pill fw-bold text-dark" onclick="document.querySelector('.topbar .dropdown-toggle').click();">
                                        @(System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "EN English" : "VN Tiếng Việt") <i class="bi bi-chevron-down ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const toggle = document.getElementById('darkModeSwitch');
        
        if(localStorage.getItem('theme') === 'dark') {
            toggle.checked = true;
        }

        toggle.addEventListener('change', function() {
            if(this.checked) {
                document.body.classList.add('dark-mode');
                localStorage.setItem('theme', 'dark');
            } else {
                document.body.classList.remove('dark-mode');
                localStorage.setItem('theme', 'light');
            }
        });
    });
</script>