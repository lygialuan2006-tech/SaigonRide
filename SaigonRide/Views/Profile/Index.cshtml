@model SaigonRide.Models.entities.RentalTransaction
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row justify-content-center super-app-bg pt-3 pb-5">
    <div class="col-md-8 col-lg-6">

        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <div>
                <h4 class="fw-bold text-dark mb-0">@Localizer["Greeting", User.Identity.Name]</h4>
                <span class="badge bg-dark rounded-pill mt-1">@User.FindFirst("UserType")?.Value Member</span>
            </div>
            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 1.2rem; font-weight: bold;">
                @User.Identity.Name.Substring(0, 1).ToUpper()
            </div>
        </div>

        <a asp-controller="Booking" asp-action="Index" class="btn-main-action shadow p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1 text-white">@Localizer["StartRide"]</h2>
                    <p class="mb-0 text-white-50 fs-6">@Localizer["FindMap"]</p>
                </div>
                <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                    <i class="bi bi-scooter fs-1 text-white"></i>
                </div>
            </div>
        </a>

        <div class="row g-3 mb-4">
            <div class="col-4">
                <a asp-controller="History" asp-action="Index" class="btn-secondary-action shadow-sm widget-card h-100">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-clock-history"></i></div>
                    <span class="fw-bold text-dark" style="font-size: 0.9rem;">@Localizer["History"]</span>
                </a>
            </div>
            <div class="col-4">
                <a asp-controller="Profile" asp-action="Index" class="btn-secondary-action shadow-sm widget-card h-100">
                    <div class="icon-box bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-gear"></i></div>
                    <span class="fw-bold text-dark" style="font-size: 0.9rem;">@Localizer["Settings"]</span>
                </a>
            </div>
            <div class="col-4">
                <a asp-controller="Profile" asp-action="Support" class="btn-secondary-action shadow-sm widget-card h-100">
                    <div class="icon-box bg-danger bg-opacity-10 text-danger"><i class="bi bi-headset"></i></div>
                    <span class="fw-bold text-dark" style="font-size: 0.9rem;">@Localizer["Support"]</span>
                </a>
            </div>
        </div>

        <h6 class="fw-bold text-muted mb-3 px-2">@Localizer["RecentActivity"]</h6>
        @if (Model != null)
        {
            <div class="card widget-card p-3 mb-4 border-start border-success border-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted d-block">@Model.StartTime.ToString("dd/MM/yyyy HH:mm")</small>
                        <span class="fw-bold text-dark">@Model.Vehicle.Category</span>
                        <span class="text-muted mx-1">→</span>
                        <span class="fw-bold text-success">@Model.ReturnStation.LocationName</span>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-light text-dark border">@Model.TotalDue.ToString("N0")đ</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card widget-card p-4 text-center mb-4 bg-white">
                <i class="bi bi-journal-x fs-1 text-muted opacity-50 mb-2"></i>
                <p class="text-muted mb-0">@Localizer["NoRidesYet"]</p>
            </div>
        }

        <div class="card widget-card bg-dark text-white p-3 overflow-hidden position-relative">
            <div class="position-relative z-1">
                <span class="badge bg-warning text-dark mb-2">@Localizer["Promo"]</span>
                <h6 class="fw-bold">@Localizer["PromoTitle"]</h6>
                <small class="text-white-50">@Localizer["PromoDesc"]</small>
            </div>
            <i class="bi bi-gift-fill position-absolute text-white opacity-10" style="font-size: 8rem; right: -20px; top: -30px;"></i>
        </div>

    </div>
</div>