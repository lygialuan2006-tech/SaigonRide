@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4 px-2">
            <a href="javascript:history.back()" class="btn btn-light rounded-circle me-3 shadow-sm text-dark"><i class="bi bi-arrow-left"></i></a>
            <div>
                <h4 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h4>
                <small class="text-muted">@Localizer["PageSubtitle"]</small>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-sm-6">
                <a href="tel:19001000" class="card border-0 shadow-sm rounded-4 text-decoration-none text-center p-4 bg-white h-100 action-card">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 50px; height: 50px;"><i class="bi bi-telephone-fill fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-1">@Localizer["CallUs"]</h6>
                    <small class="text-muted">1900 1000</small>
                </a>
            </div>
            <div class="col-sm-6">
                <a href="mailto:support@saigonride.vn" class="card border-0 shadow-sm rounded-4 text-decoration-none text-center p-4 bg-white h-100 action-card">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 50px; height: 50px;"><i class="bi bi-envelope-fill fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-1">@Localizer["EmailUs"]</h6>
                    <small class="text-muted">support@saigonride.vn</small>
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <h6 class="fw-bold text-dark mb-4"><i class="bi bi-chat-left-text-fill text-success me-2"></i> @Localizer["SendFeedback"]</h6>
            
            <form action="#" method="get" onsubmit="event.preventDefault(); alert('@Localizer["MsgSentAlert"]');">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">@Localizer["LabelTopic"]</label>
                    <select class="form-select border-light shadow-none bg-light fw-bold text-dark">
                        <option>@Localizer["Topic_AppIssue"]</option>
                        <option>@Localizer["Topic_VehicleIssue"]</option>
                        <option>@Localizer["Topic_Payment"]</option>
                        <option>@Localizer["Topic_Other"]</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">@Localizer["LabelMessage"]</label>
                    <textarea class="form-control border-light shadow-none bg-light" rows="4" placeholder="@Localizer["MsgPlaceholder"]" required></textarea>
                </div>
                <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm">@Localizer["BtnSubmit"] <i class="bi bi-send-fill ms-2"></i></button>
            </form>
        </div>
    </div>
</div>