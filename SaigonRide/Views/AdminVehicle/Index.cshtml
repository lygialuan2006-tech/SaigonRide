@model IEnumerable<SaigonRide.Models.entities.Vehicle>
@{
    ViewData["Title"] = "Quản lý Phương tiện";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var stations = ViewBag.Stations as Dictionary<int, string>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-bicycle text-warning me-2"></i>Danh sách Xe</h5>
    <a href="/AdminVehicle/Create" class="btn btn-warning text-dark fw-bold rounded-pill shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Nhập Xe mới
    </a>
</div>

<!-- THANH TÌM KIẾM XE -->
<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white">
                <span class="input-group-text bg-white border-0 text-muted ps-4"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none px-2" placeholder="Tìm theo loại xe (VD: E-Scooter)...">
                <button class="btn btn-warning fw-bold px-4 text-dark" type="submit">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
                {
                    <a href="/AdminVehicle/Index" class="btn btn-light border-start px-3" title="Xóa tìm kiếm"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="border-bottom: 2px solid #dee2e6;">
                <tr>
                    <th class="ps-4">Mã Xe</th>
                    <th>Loại Xe</th>
                    <th>Đang đỗ tại</th>
                    <th class="text-center">Đơn giá / phút</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var vehicle in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">V-@vehicle.Id.ToString("D3")</td>
                            <td class="fw-bold text-dark">@vehicle.Category</td>
                            <td>
                                <i class="bi bi-geo-alt text-success"></i>
                                @(stations != null && stations.ContainsKey(vehicle.StationId) ? stations[vehicle.StationId] : "Trạm không rõ")
                            </td>
                            <td class="text-center fw-bold text-danger">@vehicle.PricePerMinute đ</td>
                            <td class="text-center">
                                @if (vehicle.Status == SaigonRide.Models.Enums.VehicleStatus.Available)
                                {
                                    <span class="badge bg-success rounded-pill">Sẵn sàng</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark rounded-pill">Đang bảo trì</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="ToggleStatus" asp-route-id="@vehicle.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(vehicle.Status == SaigonRide.Models.Enums.VehicleStatus.Available ? "btn-outline-warning" : "btn-outline-success") me-1" title="Đổi trạng thái">
                                        <i class="bi bi-tools"></i>
                                    </button>
                                </form>
                                <a href="/AdminVehicle/Edit/@vehicle.Id" class="btn btn-sm btn-light text-primary me-1" title="Chỉnh sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@vehicle.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa chiếc xe này vĩnh viễn?');">
                                    <button type="submit" class="btn btn-sm btn-light text-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-5"><i class="bi bi-bicycle fs-1 d-block mb-3"></i>Không tìm thấy xe nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>