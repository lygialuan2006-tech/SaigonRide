@model IEnumerable<SaigonRide.Models.entities.Station>
@{
    ViewData["Title"] = "Quản lý Trạm xe";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-geo-alt-fill text-success me-2"></i>Danh sách Trạm</h5>
    <a href="/AdminStation/Create" class="btn btn-success fw-bold rounded-pill shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Thêm Trạm mới
    </a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white">
                <span class="input-group-text bg-white border-0 text-muted ps-4"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none px-2" placeholder="Tìm kiếm theo Tên khu vực trạm...">
                <button class="btn btn-success fw-bold px-4" type="submit">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
                {
                    <a href="/AdminStation/Index" class="btn btn-light border-start px-3" title="Xóa tìm kiếm"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted" style="border-bottom: 2px solid #dee2e6;">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Tên Trạm (Khu vực)</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Sức chứa / Đang đỗ</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var station in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@station.Id</td>
                            <td>
                                <div class="fw-bold text-dark">@station.LocationName</div>
                                <div class="text-muted small">@station.Latitude, @station.Longitude</div>
                            </td>
                            <td class="text-center">
                                @if (station.IsAvailable)
                                {
                                    <span class="badge bg-success rounded-pill">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill">Tạm ngưng</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill me-1" title="Sức chứa tối đa">@station.MaxCapacity</span> /
                                @if (station.CurrentInventory == 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-1" title="Đang đỗ">0</span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill ms-1" title="Đang đỗ">@station.CurrentInventory</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <!-- Nút Bật/Tắt Trạm -->
                                <form asp-action="ToggleStatus" asp-route-id="@station.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(station.IsAvailable ? "btn-outline-danger" : "btn-outline-success") me-1" title="Đổi trạng thái trạm">
                                        <i class="bi bi-power"></i>
                                    </button>
                                </form>
                                <a href="/AdminStation/Edit/@station.Id" class="btn btn-sm btn-light text-primary me-1" title="Chỉnh sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@station.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa trạm @station.LocationName không?');">
                                    <button type="submit" class="btn btn-sm btn-light text-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Không tìm thấy trạm nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>