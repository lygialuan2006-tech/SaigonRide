<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaigonRide Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f4f6f8; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { background-color: #0f4c5c; min-height: 100vh; color: white; display: flex; flex-direction: column; }
        .sidebar-logo { font-size: 1.5rem; font-weight: bold; color: white; text-decoration: none; padding: 1.5rem 1rem; display: flex; flex-direction: column; align-items: center; }
        .nav-link { color: rgba(255, 255, 255, 0.8); padding: 0.8rem 1.5rem; display: flex; align-items: center; gap: 10px; transition: all 0.3s; }
        .nav-link:hover, .nav-link.active { color: white; background-color: rgba(255, 255, 255, 0.1); border-radius: 8px; margin: 0 10px; }
        .user-panel { background-color: #1d2327; margin: 15px; padding: 15px; border-radius: 10px; text-align: center; margin-top: auto; }
        .user-avatar { width: 50px; height: 50px; background-color: #2b3640; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem; margin: 0 auto 10px auto; }
        .main-content { padding: 2rem; }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- SIDEBAR THEO CHUẨN TIẾNG VIỆT -->
            <div class="col-auto col-md-3 col-xl-2 px-0 sidebar">
                <a href="/AdminDashboard/Index" class="sidebar-logo">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi bi-scooter text-success"></i>
                        <span>SaigonRide</span>
                    </div>
                    <span class="badge bg-danger rounded-pill" style="font-size: 0.8rem;">ADMIN</span>
                </a>
                
                <hr class="mx-3 opacity-25">

                <ul class="nav flex-column mb-auto">
                    <li class="nav-item">
                        <!-- Đã sửa link trỏ về Home thay vì Intro -->
                        <a href="/Home/Index" class="nav-link text-info fw-bold">
                            <i class="bi bi-phone"></i>
                            <span>Xem giao diện<br><small>Khách (App)</small></span>
                        </a>
                    </li>
                    <li class="nav-item mt-3">
                        <a href="/AdminDashboard/Index" class="nav-link">
                            <i class="bi bi-speedometer2"></i>
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/AdminStation/Index" class="nav-link">
                            <i class="bi bi-geo-alt"></i>
                            <span>Quản lý Trạm</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/AdminVehicle/Index" class="nav-link">
                            <i class="bi bi-bicycle"></i>
                            <span>Quản lý Xe</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/AdminUser/Index" class="nav-link">
                            <i class="bi bi-people"></i>
                            <span>Quản lý User</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Transactions/Index" class="nav-link">
                            <i class="bi bi-receipt"></i>
                            <span>Giao dịch & Báo cáo</span>
                        </a>
                    </li>
     
                    <li class="nav-item">
                        <a href="/Reports/AdminReports" class="nav-link text-danger">
                            <i class="bi bi-flag-fill"></i>
                            <span>Quản lý Phản hồi</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/AdminDashboard/Announcements" class="nav-link">
                            <i class="bi bi-megaphone"></i>
                            <span>Quản lý Thông báo</span>
                        </a>
                    </li>

                <!-- USER PANEL -->
                <div class="user-panel">
                    <div class="user-avatar text-white">SA</div>
                    <div class="fw-bold text-white mb-0">System Admin</div>
                    <small class="text-success d-block mb-3">System Admin</small>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill">Đăng xuất</button>
                    </form>
                </div>
            </div>

            <!-- MAIN CONTENT -->
            <div class="col min-vh-100 bg-light">
                <div class="main-content">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>