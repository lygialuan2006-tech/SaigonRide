<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --bg-color: #f4f6f8;
            --card-bg: #ffffff;
            --text-color: #333333;
            --text-muted: #6c757d;
            --border-color: #e9ecef;
            --primary-bg: #e7f1ff; 
            --secondary-bg: #e2e3e5; 
            --danger-bg: #f8d7da; 
        }

        body.dark-mode {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #e0e0e0;
            --text-muted: #aaaaaa;
            --border-color: #333333;
            --primary-bg: #1a233a; 
            --secondary-bg: #2a2b2d; 
            --danger-bg: #3a1c1e; 
        }

        body { background-color: var(--bg-color); color: var(--text-color); transition: background-color 0.3s, color 0.3s; }
        
        body.dark-mode .card, body.dark-mode .navbar, body.dark-mode .settings-card, 
        body.dark-mode .list-group-item, body.dark-mode .dropdown-menu,
        body.dark-mode .bg-white, body.dark-mode .bg-light,
        body.dark-mode .super-app-bg, body.dark-mode .widget-card { 
            background-color: var(--card-bg) !important; border-color: var(--border-color) !important; color: var(--text-color) !important; 
        }

        body.dark-mode .bg-primary.bg-opacity-10 { background-color: var(--primary-bg) !important; color: #6ea8fe !important; }
        body.dark-mode .bg-secondary.bg-opacity-10 { background-color: var(--secondary-bg) !important; color: #a3a6cb !important; }
        body.dark-mode .bg-danger.bg-opacity-10 { background-color: var(--danger-bg) !important; color: #ea868f !important; }
        
        body.dark-mode .text-muted { color: #adb5bd !important; }
        body.dark-mode .btn-secondary-action { background-color: #212529 !important; border-color: #333 !important; }
        body.dark-mode .text-primary { color: #6ea8fe !important; }
        body.dark-mode .text-secondary { color: #a3a6cb !important; }
        body.dark-mode .text-danger { color: #ea868f !important; }
        body.dark-mode .card.bg-dark { background-color: #1a1d20 !important; border: 1px solid #333 !important; }
        
        .btn-main-action { display: block; text-decoration: none; background: linear-gradient(135deg, #20c997 0%, #198754 100%); border-radius: 1rem; transition: transform 0.2s; }
        .btn-main-action:hover { transform: translateY(-3px); }
        .btn-secondary-action { display: flex; flex-direction: column; align-items: center; justify-content: center; text-decoration: none; background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 1rem; padding: 1.25rem 0.5rem; transition: all 0.2s; }
        .btn-secondary-action:hover { background-color: var(--bg-color); transform: translateY(-2px); }
        .icon-box { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 0.75rem; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light sticky-top mb-4 py-2 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-success fs-4" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-scooter"></i> SaigonRide
                </a>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end" id="navbarApp">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link dropdown-toggle fw-bold text-color" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-globe2 text-success"></i> @(Context.Request.Cookies[Microsoft.AspNetCore.Localization.CookieRequestCultureProvider.DefaultCookieName]?.Contains("en") == true ? "EN" : "VI")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3 p-2">
                                <li>
                                    <form asp-controller="Language" asp-action="SetLanguage" method="post" class="m-0">
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <input type="hidden" name="culture" value="vi" />
                                        <button type="submit" class="dropdown-item fw-bold text-success rounded">🇻🇳 Tiếng Việt</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Language" asp-action="SetLanguage" method="post" class="m-0 mt-1">
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <input type="hidden" name="culture" value="en" />
                                        <button type="submit" class="dropdown-item text-muted rounded">🇬🇧 English</button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center text-color" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-2 shadow-sm" style="width: 38px; height: 38px;">
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px; min-width: 180px;">
                                    <li><h6 class="dropdown-header">@User.FindFirst("UserType")?.Value Account</h6></li>
                                    <!-- NÚT FIX LỖI ÁM DARK MODE -->
                                    <li><a class="dropdown-item py-2 text-danger fw-bold" href="javascript:void(0);" onclick="localStorage.removeItem('theme'); document.body.classList.remove('dark-mode'); window.location.href='/Account/Logout';"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container"><main role="main" class="pb-5">@RenderBody()</main></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if(localStorage.getItem('theme') === 'dark') { document.body.classList.add('dark-mode'); }
    </script>
</body>
</html>