@model IEnumerable<SaigonRide.Models.entities.RentalTransaction>
@{
    ViewData["Title"] = "Lịch sử Giao dịch";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Lịch sử Giao dịch & Báo cáo</h5>
    </div>
    <div class="p-3 border-bottom bg-light bg-opacity-50">
        <form method="get" asp-action="Index" class="d-flex w-50">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-start-0 shadow-none" placeholder="Tìm Mã GD, Khách hàng hoặc Phương tiện..." />
                <button type="submit" class="btn btn-primary fw-bold px-4">Tìm</button>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
            {
                <a href="/Transactions/Index" class="btn btn-light border ms-2">Xóa</a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-4">Mã GD</th>
                        <th>Khách hàng</th>
                        <th>Phương tiện</th>
                        <th>Thời gian thuê</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                                <td>@item.User?.FullName</td>
                                <td>@item.Vehicle?.Category</td>
                                <td>@item.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-success">@item.TotalDue.ToString("N0") ₫</td>
                                <td><span class="badge bg-success">Hoàn tất</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có giao dịch nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>